{
  "name": "@metamask/connect-stellar",
  "version": "0.2.0",
  "license": "ISC",
  "description": "The MetaMask Connect Stellar adapter",
  "homepage": "https://github.com/MetaMask/connect-stellar#readme",
  "bugs": {
    "url": "https://github.com/MetaMask/connect-stellar/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/MetaMask/connect-stellar.git"
  },
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "ts-bridge --project tsconfig.build.json --clean",
    "build:docs": "typedoc",
    "build:types": "tsc --project tsconfig.build.json",
    "format": "biome format",
    "format:fix": "biome format --write",
    "lint": "yarn lint:biome && yarn format && yarn lint:constraints && yarn lint:dependencies --check && yarn lint:changelog",
    "lint:changelog": "auto-changelog validate --prettier",
    "lint:constraints": "yarn constraints",
    "lint:dependencies": "depcheck && yarn dedupe",
    "lint:biome": "biome check",
    "lint:fix": "yarn lint:biome --fix && yarn format:fix && yarn lint:constraints --fix && yarn lint:dependencies && yarn lint:changelog",
    "prepack": "./scripts/prepack.sh",
    "test": "vitest && attw --pack",
    "test:watch": "vitest --watch"
  },
  "dependencies": {
    "@metamask/multichain-api-client": "^0.11.0"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.15.3",
    "@biomejs/biome": "^1.8.3",
    "@creit.tech/stellar-wallets-kit": "^2.1.0",
    "@lavamoat/allow-scripts": "^3.0.4",
    "@lavamoat/preinstall-always-fail": "^2.0.0",
    "@metamask/auto-changelog": "^6.1.0",
    "@ts-bridge/cli": "^0.6.3",
    "@types/node": "^22.13.13",
    "@vitest/coverage-istanbul": "^3.0.7",
    "@vitest/eslint-plugin": "^1.1.4",
    "@yarnpkg/types": "^4.0.0-rc.52",
    "depcheck": "^1.4.3",
    "prettier": "^3.5.3",
    "ts-node": "^10.7.0",
    "typedoc": "^0.26.11",
    "typescript": "~5.7.3",
    "vite": "^6.4.1",
    "vitest": "^3.0.7"
  },
  "packageManager": "yarn@4.1.1",
  "engines": {
    "node": "^18.20 || ^20.17 || >=22"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "lavamoat": {
    "allowScripts": {
      "@lavamoat/preinstall-always-fail": false,
      "vite>esbuild": false,
      "@biomejs/biome": false,
      "vitest>vite-node>vite>esbuild": false,
      "vitest>vite>esbuild": false,
      "@creit.tech/stellar-wallets-kit>@hot-wallet/sdk>@near-js/crypto>secp256k1": false,
      "@creit.tech/stellar-wallets-kit>@reown/appkit": false,
      "@creit.tech/stellar-wallets-kit>@reown/appkit>viem>ws>bufferutil": false,
      "@creit.tech/stellar-wallets-kit>@reown/appkit>viem>ws>utf-8-validate": false,
      "@creit.tech/stellar-wallets-kit>@trezor/connect-plugin-stellar>@stellar/stellar-sdk": false,
      "@creit.tech/stellar-wallets-kit>@trezor/connect-web>@trezor/connect>@trezor/protobuf>protobufjs": false,
      "@creit.tech/stellar-wallets-kit>@trezor/connect-web>@trezor/connect>@trezor/transport>usb": false,
      "@creit.tech/stellar-wallets-kit>@trezor/connect-web>@trezor/connect>@trezor/utxo-lib>blake-hash": false,
      "@creit.tech/stellar-wallets-kit>@trezor/connect-web>@trezor/connect>@trezor/utxo-lib>tiny-secp256k1": false
    }
  }
}
